#!/usr/bin/env node

'use strict'

const { resolve } = require('path')
const { parseArgs } = require('util')
const { Store, keyFromText, totp } = require('../')

const STORE_PATH = resolve(process.env.HOME, process.env.TOTP_PATH)
const STORE_KEY = process.env.TOTP_KEY

const { values: config, positionals } = parseArgs({
  options: {
    add:    { short: 'a', type: 'string' },
    delete: { short: 'd', type: 'string' }
  },
  strict: true,
  allowPositionals: true
})

function getStore () {
  return Store.open(STORE_PATH, STORE_KEY)
}

const commands = {
  async add ({ add: name }, [key]) {
    let store = await getStore()
    await store.add(name, key)
  },

  async delete ({ delete: name }) {
    let store = await getStore()
    await store.delete(name)
  },

  async main () {
    let store = await getStore()
    let keys = await store.allKeys()

    for (let { name, key } of keys) {
      let code = totp(keyFromText(key))
      console.log('    ', code, '  ', name)
    }
  }
}

let cmd = 'main'
if (config.add !== undefined) cmd = 'add'
if (config.delete !== undefined) cmd = 'delete'

commands[cmd](config, positionals).catch(console.error)
